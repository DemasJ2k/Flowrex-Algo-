# Database
DATABASE_URL=postgresql://flowrex:flowrex@localhost:5432/flowrex_algo

# Auth
SECRET_KEY=change-this-to-a-strong-random-string

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Debug mode (set to false in production)
DEBUG=true

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Oanda (Practice Account) ──────────────────────────────────
# Get API key from: https://www.oanda.com/demo-account/tpa/personal_token
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_PRACTICE=true

# ── cTrader (Open API) ────────────────────────────────────────
# Register app at: https://openapi.ctrader.com/
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=

# ── MT5 (optional, Windows only) ──────────────────────────────
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
# MT5_LOGIN=
# MT5_PASSWORD=
# MT5_SERVER=

# ── News / Data APIs ─────────────────────────────────────────
# Finnhub (economic calendar): https://finnhub.io/
FINNHUB_API_KEY=
# AlphaVantage (news sentiment): https://www.alphavantage.co/
ALPHAVANTAGE_API_KEY=
# NewsAPI (headlines): https://newsapi.org/
NEWSAPI_API_KEY=
